# Backend environment — copy to `.env` and fill in your values.

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chat-app

# Auth — use a long random string (e.g. `openssl rand -base64 32`)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Email (password reset & verification) — Gmail SMTP.
# Leave GMAIL_* blank in development — emails are printed to the console instead.
# For real delivery: Google Account -> Security -> 2-Step Verification ->
# App passwords -> generate one, then set:
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
MAIL_FROM=Plume <your-address@gmail.com>

# AI features (OpenRouter). Get a key at https://openrouter.ai/keys
# Leave blank to disable AI; the frontend hides the buttons and the API returns 503.
OPENROUTER_API_KEY=
# Optional: override the model fallback chain (comma-separated, tried in order).
# AI_MODELS=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,openai/gpt-oss-120b:free,nvidia/nemotron-3-nano-30b-a3b:free
