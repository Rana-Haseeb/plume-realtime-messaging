# Backend environment — copy to `.env` and fill in your values.

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chat-app

# Auth — use a long random string (e.g. `openssl rand -base64 32`)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Email (password reset & verification).
# Leave RESEND_API_KEY blank in development — emails are printed to the console.
# For real delivery, create a key at https://resend.com and set a verified sender.
RESEND_API_KEY=
MAIL_FROM=Plume <onboarding@resend.dev>
