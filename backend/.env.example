# Backend environment — copy to `.env` and fill in your values.

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chat-app

# Auth — use a long random string (e.g. `openssl rand -base64 32`)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Email (password reset & verification) — Gmail SMTP.
# Leave GMAIL_* blank in development — emails are printed to the console instead.
# For real delivery: Google Account -> Security -> 2-Step Verification ->
# App passwords -> generate one, then set:
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
MAIL_FROM=Plume <your-address@gmail.com>
